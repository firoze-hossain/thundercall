<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.web.WebView?>
<?import org.fxmisc.richtext.CodeArea?>
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.roze.thundercall.ui.controllers.MainController"
           stylesheets="@../css/main.css">

    <fx:define>
        <ToggleGroup fx:id="sidebarRailGroup"/>
    </fx:define>

    <BorderPane>
        <!-- ============ TOP: menu bar + header + workspace bar (Postman rows 1-3) ============ -->
        <top>
            <VBox>
                <!-- Row 1: application menu bar -->
                <MenuBar styleClass="app-menu-bar">
                    <Menu text="File">
                        <MenuItem text="New Collection" onAction="#handleNewCollection"/>
                        <MenuItem text="New Environment" onAction="#handleNewEnvironment"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Import…" onAction="#handleImportCollections"/>
                        <MenuItem text="Export…" onAction="#handleExportCollections"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Settings…" onAction="#handleSettings"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Logout" onAction="#handleLogout"/>
                        <MenuItem text="Exit" onAction="#handleExit"/>
                    </Menu>
                    <Menu text="View">
                        <MenuItem text="Dark Theme" onAction="#handleThemeDark"/>
                        <MenuItem text="Light Theme" onAction="#handleThemeLight"/>
                    </Menu>
                    <Menu text="Help">
                        <MenuItem text="About Thundercall" onAction="#handleAbout"/>
                    </Menu>
                </MenuBar>

                <!-- Row 2: Home / Workspaces / API Network  ...  status / settings / user -->
                <HBox styleClass="header" spacing="4" alignment="CENTER_LEFT" prefHeight="46">
                    <padding>
                        <Insets left="12" right="12" top="6" bottom="6"/>
                    </padding>
                    <ImageView fitHeight="24" fitWidth="24" preserveRatio="true">
                        <Image url="@../images/logo.png"/>
                    </ImageView>
                    <Label text="Home" styleClass="nav-item"/>
                    <MenuButton fx:id="workspacesMenuBtn" text="Workspaces" styleClass="nav-item-menu">
                        <items>
                            <MenuItem text="My Workspace"/>
                            <SeparatorMenuItem/>
                            <MenuItem text="Create Workspace…" onAction="#handleCreateWorkspace"/>
                        </items>
                    </MenuButton>
                    <Label text="API Network" styleClass="nav-item"/>

                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="globalSearchField" styleClass="global-search"
                               promptText="Search Thundercall  (Ctrl+K)" prefWidth="300"
                               onAction="#handleGlobalSearch"/>
                    <Region HBox.hgrow="ALWAYS"/>

                    <HBox alignment="CENTER" spacing="5" styleClass="connection-status">
                        <Circle radius="4" styleClass="status-indicator"/>
                        <Label text="Connected" styleClass="status-text"/>
                    </HBox>
                    <Button styleClass="icon-button" onAction="#handleSettings">
                        <tooltip>
                            <Tooltip text="Settings"/>
                        </tooltip>
                        <graphic>
                            <Label text="⚙" styleClass="gear-icon"/>
                        </graphic>
                    </Button>
                    <MenuButton text="User" styleClass="user-menu">
                        <graphic>
                            <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
                                <Image url="@../images/user-icon.png"/>
                            </ImageView>
                        </graphic>
                        <items>
                            <MenuItem text="Profile" onAction="#handleProfile"/>
                            <MenuItem text="Settings" onAction="#handleSettings"/>
                            <SeparatorMenuItem/>
                            <MenuItem text="Logout" onAction="#handleLogout"/>
                        </items>
                    </MenuButton>
                </HBox>

                <!-- Row 3: workspace bar -->
                <HBox styleClass="workspace-bar" spacing="8" alignment="CENTER_LEFT" prefHeight="40">
                    <padding>
                        <Insets left="12" right="12" top="5" bottom="5"/>
                    </padding>
                    <Label fx:id="workspaceNameLabel" text="My Workspace" styleClass="workspace-name"/>
                    <MenuButton text="New" styleClass="workspace-btn">
                        <items>
                            <MenuItem text="Collection" onAction="#handleNewCollection"/>
                            <MenuItem text="Environment" onAction="#handleNewEnvironment"/>
                            <MenuItem text="Request" onAction="#handleAddRequest"/>
                        </items>
                    </MenuButton>
                    <Button text="Import" styleClass="workspace-btn" onAction="#handleImportCollections"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="environmentCombo" styleClass="environment-combo"
                              promptText="No Environment" prefWidth="200"/>
                </HBox>
            </VBox>
        </top>

        <!-- ============ LEFT: Postman icon rail + switchable sidebar ============ -->
        <left>
            <HBox>
                <!-- Icon rail -->
                <VBox styleClass="icon-rail" spacing="4" alignment="TOP_CENTER" prefWidth="78">
                    <padding>
                        <Insets top="8" bottom="8" left="4" right="4"/>
                    </padding>
                    <ToggleButton fx:id="railCollectionsBtn" text="Collections" styleClass="rail-btn"
                                  toggleGroup="$sidebarRailGroup" selected="true"
                                  onAction="#handleShowCollections" maxWidth="10000">
                        <graphic>
                            <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                                <Image url="@../images/collection-icon.png"/>
                            </ImageView>
                        </graphic>
                        <contentDisplay>TOP</contentDisplay>
                    </ToggleButton>
                    <ToggleButton fx:id="railEnvironmentsBtn" text="Environments" styleClass="rail-btn"
                                  toggleGroup="$sidebarRailGroup"
                                  onAction="#handleShowEnvironments" maxWidth="10000">
                        <graphic>
                            <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                                <Image url="@../images/folder-icon.png"/>
                            </ImageView>
                        </graphic>
                        <contentDisplay>TOP</contentDisplay>
                    </ToggleButton>
                    <ToggleButton fx:id="railHistoryBtn" text="History" styleClass="rail-btn"
                                  toggleGroup="$sidebarRailGroup"
                                  onAction="#handleShowHistory" maxWidth="10000">
                        <graphic>
                            <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                                <Image url="@../images/request-icon.png"/>
                            </ImageView>
                        </graphic>
                        <contentDisplay>TOP</contentDisplay>
                    </ToggleButton>
                </VBox>

                <!-- Switchable sidebar -->
                <StackPane prefWidth="264" styleClass="sidebar">
                    <!-- Collections pane (default) -->
                    <VBox fx:id="collectionsPane" spacing="6">
                        <padding>
                            <Insets top="8" right="8" bottom="8" left="8"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT" spacing="4" styleClass="sidebar-header">
                            <Label text="Collections" styleClass="section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button styleClass="icon-button" onAction="#handleAddRequest" fx:id="addRequestBtn">
                                <tooltip>
                                    <Tooltip text="New request"/>
                                </tooltip>
                                <graphic>
                                    <ImageView fitHeight="14" fitWidth="14" preserveRatio="true">
                                        <Image url="@../images/add-icon.png"/>
                                    </ImageView>
                                </graphic>
                            </Button>
                            <MenuButton styleClass="icon-button" fx:id="collectionsMenuBtn">
                                <graphic>
                                    <ImageView fitHeight="14" fitWidth="14" preserveRatio="true">
                                        <Image url="@../images/more-icon.png"/>
                                    </ImageView>
                                </graphic>
                                <items>
                                    <MenuItem text="New Collection" onAction="#handleNewCollection"/>
                                    <MenuItem text="Refresh" onAction="#handleRefreshCollections"/>
                                    <SeparatorMenuItem/>
                                    <MenuItem text="Import Collection…" onAction="#handleImportCollections"/>
                                    <MenuItem text="Export Collection…" onAction="#handleExportCollections"/>
                                </items>
                            </MenuButton>
                        </HBox>
                        <TextField fx:id="collectionsSearchField" styleClass="sidebar-search"
                                   promptText="Search collections"/>
                        <TreeView fx:id="collectionsTree" styleClass="collectionResponses-tree"
                                  showRoot="false" VBox.vgrow="ALWAYS"/>
                    </VBox>

                    <!-- Environments pane -->
                    <VBox fx:id="environmentsPane" spacing="6" visible="false">
                        <padding>
                            <Insets top="8" right="8" bottom="8" left="8"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT" styleClass="sidebar-header">
                            <Label text="Environments" styleClass="section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button styleClass="icon-button" onAction="#handleNewEnvironment">
                                <tooltip>
                                    <Tooltip text="New environment"/>
                                </tooltip>
                                <graphic>
                                    <ImageView fitHeight="14" fitWidth="14" preserveRatio="true">
                                        <Image url="@../images/add-icon.png"/>
                                    </ImageView>
                                </graphic>
                            </Button>
                        </HBox>
                        <Label styleClass="sidebar-hint" wrapText="true"
                               text="Double-click an environment to edit its variables. Pick the active one at the top right."/>
                        <ListView fx:id="environmentsList" styleClass="history-list" VBox.vgrow="ALWAYS"/>
                    </VBox>

                    <!-- History pane -->
                    <VBox fx:id="historyPane" spacing="6" visible="false">
                        <padding>
                            <Insets top="8" right="8" bottom="8" left="8"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT" styleClass="sidebar-header">
                            <Label text="History" styleClass="section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button styleClass="icon-button" onAction="#handleClearHistory">
                                <tooltip>
                                    <Tooltip text="Clear history"/>
                                </tooltip>
                                <graphic>
                                    <ImageView fitHeight="14" fitWidth="14" preserveRatio="true">
                                        <Image url="@../images/clear-icon.png"/>
                                    </ImageView>
                                </graphic>
                            </Button>
                        </HBox>
                        <ListView fx:id="historyList" styleClass="history-list" VBox.vgrow="ALWAYS"/>
                    </VBox>
                </StackPane>
            </HBox>
        </left>

        <!-- ============ CENTER: request builder + response viewer ============ -->
        <center>
            <SplitPane orientation="VERTICAL" dividerPositions="0.55" styleClass="main-split">
                <!-- Request builder -->
                <VBox styleClass="requestResponse-panel">
                    <!-- Postman-style open-request tabs -->
                    <TabPane fx:id="requestTabPane" styleClass="request-tab-bar"
                             tabClosingPolicy="ALL_TABS"
                             minHeight="36" prefHeight="36" maxHeight="36"/>
                    <HBox styleClass="url-bar" spacing="8" alignment="CENTER_LEFT">
                        <ComboBox fx:id="methodCombo" styleClass="method-combo" prefWidth="110"/>
                        <StackPane HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                            <Label fx:id="urlPromptLabel" styleClass="url-prompt-label"
                                   text="Enter URL or paste text — use {{variables}} from the selected environment"
                                   mouseTransparent="true"/>
                            <CodeArea fx:id="urlField" styleClass="url-field"/>
                        </StackPane>
                        <Button text="Send" styleClass="send-button" onAction="#handleSendRequest"/>
                        <Button styleClass="icon-button" onAction="#handleSaveRequest">
                            <tooltip>
                                <Tooltip text="Save request"/>
                            </tooltip>
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                    <Image url="@../images/save-icon.png"/>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button styleClass="icon-button" onAction="#handleSamplePostRequest">
                            <tooltip>
                                <Tooltip text="Load sample POST request"/>
                            </tooltip>
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                    <Image url="@../images/sample-icon.png"/>
                                </ImageView>
                            </graphic>
                        </Button>
                    </HBox>

                    <!-- Request tabs: Postman order -->
                    <TabPane styleClass="requestResponse-tabs" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                        <tabs>
                            <Tab text="Params">
                                <VBox>
                                    <TableView fx:id="paramsTable" styleClass="key-value-table" VBox.vgrow="ALWAYS">
                                        <columns>
                                            <TableColumn text="Key" prefWidth="180">
                                                <cellValueFactory>
                                                    <PropertyValueFactory property="key"/>
                                                </cellValueFactory>
                                                <cellFactory>
                                                    <TextFieldTableCell fx:factory="forTableColumn"/>
                                                </cellFactory>
                                            </TableColumn>
                                            <TableColumn text="Value" prefWidth="260">
                                                <cellValueFactory>
                                                    <PropertyValueFactory property="value"/>
                                                </cellValueFactory>
                                                <cellFactory>
                                                    <TextFieldTableCell fx:factory="forTableColumn"/>
                                                </cellFactory>
                                            </TableColumn>
                                            <TableColumn text="Description" prefWidth="200">
                                                <cellValueFactory>
                                                    <PropertyValueFactory property="description"/>
                                                </cellValueFactory>
                                                <cellFactory>
                                                    <TextFieldTableCell fx:factory="forTableColumn"/>
                                                </cellFactory>
                                            </TableColumn>
                                        </columns>
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/>
                                        </columnResizePolicy>
                                    </TableView>
                                    <HBox alignment="CENTER_RIGHT" styleClass="table-button-bar" spacing="8">
                                        <Button text="Add Row" onAction="#handleAddParamRow"
                                                styleClass="add-row-button"/>
                                        <Button text="Delete Row" onAction="#handleDeleteParamRow"
                                                styleClass="delete-row-button"/>
                                    </HBox>
                                </VBox>
                            </Tab>

                            <Tab text="Authorization">
                                <VBox spacing="10" styleClass="auth-panel">
                                    <Label text="Type" styleClass="scripts-section-label"/>
                                    <ComboBox fx:id="authTypeCombo" promptText="Select Auth Type" prefWidth="240"/>
                                    <Label fx:id="authHintLabel" styleClass="sidebar-hint" wrapText="true"
                                           text="Use a {{variable}} to pull the value from the selected environment — e.g. {{Token}}."/>
                                    <TextField fx:id="tokenField" promptText="Token, e.g. {{Token}} or {{ACCESS_TOKEN}}"
                                               managed="false" visible="false"/>
                                    <HBox spacing="10" fx:id="basicAuthBox" managed="false" visible="false">
                                        <TextField fx:id="usernameField" promptText="Username (supports {{variables}})" HBox.hgrow="ALWAYS"/>
                                        <PasswordField fx:id="passwordField" promptText="Password" HBox.hgrow="ALWAYS"/>
                                    </HBox>
                                </VBox>
                            </Tab>

                            <Tab text="Headers">
                                <VBox>
                                    <TableView fx:id="headersTable" styleClass="key-value-table" VBox.vgrow="ALWAYS">
                                        <columns>
                                            <TableColumn text="Key" prefWidth="180">
                                                <cellValueFactory>
                                                    <PropertyValueFactory property="key"/>
                                                </cellValueFactory>
                                                <cellFactory>
                                                    <TextFieldTableCell fx:factory="forTableColumn"/>
                                                </cellFactory>
                                            </TableColumn>
                                            <TableColumn text="Value" prefWidth="260">
                                                <cellValueFactory>
                                                    <PropertyValueFactory property="value"/>
                                                </cellValueFactory>
                                                <cellFactory>
                                                    <TextFieldTableCell fx:factory="forTableColumn"/>
                                                </cellFactory>
                                            </TableColumn>
                                            <TableColumn text="Description" prefWidth="200">
                                                <cellValueFactory>
                                                    <PropertyValueFactory property="description"/>
                                                </cellValueFactory>
                                                <cellFactory>
                                                    <TextFieldTableCell fx:factory="forTableColumn"/>
                                                </cellFactory>
                                            </TableColumn>
                                        </columns>
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/>
                                        </columnResizePolicy>
                                    </TableView>
                                    <HBox alignment="CENTER_RIGHT" styleClass="table-button-bar" spacing="8">
                                        <Button text="Add Row" onAction="#handleAddHeaderRow"
                                                styleClass="add-row-button"/>
                                        <Button text="Delete Row" onAction="#handleDeleteHeaderRow"
                                                styleClass="delete-row-button"/>
                                    </HBox>
                                </VBox>
                            </Tab>

                            <Tab text="Body">
                                <VBox>
                                    <HBox styleClass="body-type-selector">
                                        <ToggleButton fx:id="noneBodyTypeButton" text="None"
                                                      styleClass="body-type-btn"/>
                                        <ToggleButton fx:id="rawBodyTypeButton" text="Raw" styleClass="body-type-btn"/>
                                        <ToggleButton fx:id="formDataBodyTypeButton" text="Form Data"
                                                      styleClass="body-type-btn"/>
                                        <ToggleButton fx:id="urlEncodedBodyTypeButton" text="x-www-form-urlencoded"
                                                      styleClass="body-type-btn"/>
                                    </HBox>
                                    <StackPane VBox.vgrow="ALWAYS">
                                        <Label fx:id="bodyPromptLabel" styleClass="body-prompt-label"
                                               text="Request body content" mouseTransparent="true"/>
                                        <CodeArea fx:id="bodyTextArea" styleClass="body-textarea"/>
                                        <TableView fx:id="formDataTable" styleClass="key-value-table" visible="false">
                                            <columns>
                                                <TableColumn text="Key" prefWidth="180">
                                                    <cellValueFactory>
                                                        <PropertyValueFactory property="key"/>
                                                    </cellValueFactory>
                                                    <cellFactory>
                                                        <TextFieldTableCell fx:factory="forTableColumn"/>
                                                    </cellFactory>
                                                </TableColumn>
                                                <TableColumn text="Value" prefWidth="260">
                                                    <cellValueFactory>
                                                        <PropertyValueFactory property="value"/>
                                                    </cellValueFactory>
                                                    <cellFactory>
                                                        <TextFieldTableCell fx:factory="forTableColumn"/>
                                                    </cellFactory>
                                                </TableColumn>
                                                <TableColumn text="Description" prefWidth="200">
                                                    <cellValueFactory>
                                                        <PropertyValueFactory property="description"/>
                                                    </cellValueFactory>
                                                    <cellFactory>
                                                        <TextFieldTableCell fx:factory="forTableColumn"/>
                                                    </cellFactory>
                                                </TableColumn>
                                            </columns>
                                        </TableView>
                                    </StackPane>
                                    <HBox alignment="CENTER_RIGHT" styleClass="table-button-bar" spacing="8">
                                        <Button text="Add Row" onAction="#handleAddFormDataRow"
                                                styleClass="add-row-button"/>
                                        <Button text="Delete Row" onAction="#handleDeleteFormDataRow"
                                                styleClass="delete-row-button"/>
                                    </HBox>
                                </VBox>
                            </Tab>

                            <Tab text="Scripts">
                                <VBox spacing="10" styleClass="scripts-panel">
                                    <Label text="Pre-request Scripts" styleClass="scripts-section-label"/>
                                    <TextArea fx:id="preRequestScriptsArea"
                                              promptText="Runs before send. Supported: pm.environment.set(&quot;KEY&quot;, &quot;value&quot;), pm.environment.get(&quot;KEY&quot;), pm.environment.unset(&quot;KEY&quot;)"
                                              styleClass="scripts-textarea" VBox.vgrow="ALWAYS"/>
                                    <Label text="Tests (Post-request Scripts)" styleClass="scripts-section-label"/>
                                    <TextArea fx:id="postRequestScriptsArea"
                                              promptText="Runs after the response. Supported: const d = pm.response.json().data;  pm.environment.set(&quot;TOKEN&quot;, d.token);  pm.response.code"
                                              styleClass="scripts-textarea" VBox.vgrow="ALWAYS"/>
                                    <HBox spacing="10" alignment="CENTER_RIGHT">
                                        <Button text="Run Tests" onAction="#handleRunTests" styleClass="run-tests-btn"/>
                                    </HBox>
                                </VBox>
                            </Tab>
                        </tabs>
                    </TabPane>
                </VBox>

                <!-- Response viewer -->
                <VBox styleClass="response-panel">
                    <HBox styleClass="response-status-bar" spacing="15" alignment="CENTER_LEFT">
                        <Label text="Response" styleClass="response-title"/>
                        <Label fx:id="statusLabel" text="Status: " styleClass="status-label"/>
                        <Label fx:id="timeLabel" text="Time: " styleClass="time-label"/>
                        <Label fx:id="sizeLabel" text="Size: " styleClass="size-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button styleClass="icon-button" onAction="#handleCopyResponse">
                            <tooltip>
                                <Tooltip text="Copy response"/>
                            </tooltip>
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                    <Image url="@../images/copy-icon.png"/>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button styleClass="icon-button" onAction="#handleSaveResponse">
                            <tooltip>
                                <Tooltip text="Save response"/>
                            </tooltip>
                            <graphic>
                                <ImageView fitWidth="16" fitHeight="16" preserveRatio="true">
                                    <Image url="@../images/save-icon.png"/>
                                </ImageView>
                            </graphic>
                        </Button>
                    </HBox>

                    <TabPane styleClass="response-tabs" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                        <tabs>
                            <Tab text="Body">
                                <SplitPane orientation="HORIZONTAL" dividerPositions="0.7">
                                    <StackPane>
                                        <Label fx:id="responsePromptLabel" styleClass="response-prompt-label"
                                               text="Click Send to get a response" mouseTransparent="true"/>
                                        <CodeArea fx:id="responseBodyArea" styleClass="response-body" editable="false"/>
                                        <VBox fx:id="responseSearchBarContainer" alignment="TOP_RIGHT"
                                              pickOnBounds="false" StackPane.alignment="TOP_RIGHT">
                                            <padding>
                                                <Insets top="8" right="8"/>
                                            </padding>
                                        </VBox>
                                    </StackPane>
                                    <WebView fx:id="responsePreview"/>
                                </SplitPane>
                            </Tab>
                            <Tab text="Cookies">
                                <TableView fx:id="cookiesTable" styleClass="key-value-table">
                                    <columns>
                                        <TableColumn text="Name" prefWidth="180">
                                            <cellValueFactory>
                                                <PropertyValueFactory property="key"/>
                                            </cellValueFactory>
                                        </TableColumn>
                                        <TableColumn text="Value" prefWidth="260">
                                            <cellValueFactory>
                                                <PropertyValueFactory property="value"/>
                                            </cellValueFactory>
                                        </TableColumn>
                                        <TableColumn text="Domain" prefWidth="180">
                                            <cellValueFactory>
                                                <PropertyValueFactory property="description"/>
                                            </cellValueFactory>
                                        </TableColumn>
                                    </columns>
                                </TableView>
                            </Tab>
                            <Tab text="Headers">
                                <TableView fx:id="responseHeadersTable" styleClass="key-value-table">
                                    <columns>
                                        <TableColumn text="Key" prefWidth="220">
                                            <cellValueFactory>
                                                <PropertyValueFactory property="key"/>
                                            </cellValueFactory>
                                        </TableColumn>
                                        <TableColumn text="Value" prefWidth="400">
                                            <cellValueFactory>
                                                <PropertyValueFactory property="value"/>
                                            </cellValueFactory>
                                        </TableColumn>
                                    </columns>
                                </TableView>
                            </Tab>
                            <Tab text="Tests">
                                <VBox spacing="10">
                                    <Label styleClass="sidebar-hint" wrapText="true"
                                           text="Results from the request's Scripts tab appear here automatically after each Send."/>
                                    <ListView fx:id="testResultsList" styleClass="test-results" VBox.vgrow="ALWAYS"/>
                                </VBox>
                            </Tab>
                        </tabs>
                    </TabPane>
                </VBox>
            </SplitPane>
        </center>

        <!-- ============ BOTTOM: status bar ============ -->
        <bottom>
            <HBox styleClass="status-bar" spacing="10" alignment="CENTER_LEFT">
                <Label text="Ready" fx:id="statusMessage" styleClass="status-message"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="v1.0.0" styleClass="version-label"/>
            </HBox>
        </bottom>
    </BorderPane>
</StackPane>
