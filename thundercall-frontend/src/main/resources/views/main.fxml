<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.web.WebView?>
<?import org.fxmisc.richtext.CodeArea?>
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.roze.thundercall.ui.controllers.MainController"
           stylesheets="@../css/main.css">

    <fx:define>
        <ToggleGroup fx:id="sidebarRailGroup"/>
    </fx:define>

    <BorderPane>
        <!-- ============ TOP: menu bar + header + workspace bar (Postman rows 1-3) ============ -->
        <top>
            <VBox>
                <!-- Row 1: application menu bar -->
                <MenuBar styleClass="app-menu-bar">
                    <Menu text="File">
                        <MenuItem text="New Collection" onAction="#handleNewCollection"/>
                        <MenuItem text="New Environment" onAction="#handleNewEnvironment"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Import…" onAction="#handleImportCollections"/>
                        <MenuItem text="Export…" onAction="#handleExportCollections"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Settings…" onAction="#handleSettings"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Logout" onAction="#handleLogout"/>
                        <MenuItem text="Exit" onAction="#handleExit"/>
                    </Menu>
                    <Menu text="View">
                        <MenuItem text="Dark Theme" onAction="#handleThemeDark"/>
                        <MenuItem text="Light Theme" onAction="#handleThemeLight"/>
                    </Menu>
                    <Menu text="Help">
                        <MenuItem text="About Thundercall" onAction="#handleAbout"/>
                    </Menu>
                </MenuBar>

                <!-- Row 2: Home / Workspaces / API Network  ...  status / settings / user -->
                <HBox styleClass="header" spacing="4" alignment="CENTER_LEFT" prefHeight="46">
                    <padding>
                        <Insets left="12" right="12" top="6" bottom="6"/>
                    </padding>
                    <ImageView fitHeight="24" fitWidth="24" preserveRatio="true">
                        <Image url="@../images/logo.png"/>
                    </ImageView>
                    <Label text="Home" styleClass="nav-item"/>
                    <MenuButton fx:id="workspacesMenuBtn" text="Workspaces" styleClass="nav-item-menu">
                        <items>
                            <MenuItem text="My Workspace"/>
                            <SeparatorMenuItem/>
                            <MenuItem text="Create Workspace…" onAction="#handleCreateWorkspace"/>
                        </items>
                    </MenuButton>
                    <Label text="API Network" styleClass="nav-item"/>

                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="globalSearchField" styleClass="global-search"
                               promptText="Search Thundercall  (Ctrl+K)" prefWidth="300"
                               onAction="#handleGlobalSearch" onMouseClicked="#handleGlobalSearchFieldClicked"/>
                    <Region HBox.hgrow="ALWAYS"/>

                    <HBox alignment="CENTER" spacing="5" styleClass="connection-status">
                        <Circle radius="4" styleClass="status-indicator"/>
                        <Label text="Connected" styleClass="status-text"/>
                    </HBox>
                    <Button styleClass="icon-button" onAction="#handleSettings">
                        <tooltip>
                            <Tooltip text="Settings"/>
                        </tooltip>
                        <graphic>
                            <Label text="⚙" styleClass="gear-icon"/>
                        </graphic>
                    </Button>
                    <MenuButton text="User" styleClass="user-menu">
                        <graphic>
                            <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
                                <Image url="@../images/user-icon.png"/>
                            </ImageView>
                        </graphic>
                        <items>
                            <MenuItem text="Profile" onAction="#handleProfile"/>
                            <MenuItem text="Settings" onAction="#handleSettings"/>
                            <SeparatorMenuItem/>
                            <MenuItem text="Logout" onAction="#handleLogout"/>
                        </items>
                    </MenuButton>
                </HBox>

                <!-- Row 3: workspace bar -->
                <HBox styleClass="workspace-bar" spacing="8" alignment="CENTER_LEFT" prefHeight="40">
                    <padding>
                        <Insets left="12" right="12" top="5" bottom="5"/>
                    </padding>
                    <Label fx:id="workspaceNameLabel" text="My Workspace" styleClass="workspace-name"/>
                    <MenuButton text="New" styleClass="workspace-btn">
                        <items>
                            <MenuItem text="Collection" onAction="#handleNewCollection"/>
                            <MenuItem text="Environment" onAction="#handleNewEnvironment"/>
                            <MenuItem text="Request" onAction="#handleAddRequest"/>
                        </items>
                    </MenuButton>
                    <Button text="Import" styleClass="workspace-btn" onAction="#handleImportCollections"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="environmentCombo" styleClass="environment-combo"
                              promptText="No Environment" prefWidth="200"/>
                </HBox>
            </VBox>
        </top>

        <!-- ============ LEFT: Postman icon rail + switchable sidebar ============ -->
        <!-- ============ CENTER: icon rail + resizable sidebar + request/response ============ -->
        <center>
            <!-- FIX: the icon rail used to be a plain VBox sitting OUTSIDE
                 the SplitPane entirely — fixed at 78px with no divider,
                 so on a narrow window its labels ("Collections",
                 "Environments"...) truncated into "C...", "E...", "H..."
                 with no way to fix it by dragging anything. It's now the
                 SplitPane's own first segment: drag its divider to widen
                 it back out (labels reappear in full) or narrow it down
                 to icons only — same orange-on-hover divider as the
                 sidebar/response ones. -->
            <SplitPane fx:id="sidebarSplitPane" orientation="HORIZONTAL" dividerPositions="0.09, 0.27"
                       styleClass="sidebar-split-pane">
                <VBox styleClass="icon-rail" spacing="4" alignment="TOP_CENTER"
                      prefWidth="78" minWidth="56" maxWidth="160">
                    <padding>
                        <Insets top="8" bottom="8" left="4" right="4"/>
                    </padding>
                    <ToggleButton fx:id="railCollectionsBtn" text="Collections" styleClass="rail-btn"
                                  toggleGroup="$sidebarRailGroup" selected="true"
                                  onAction="#handleShowCollections" maxWidth="10000">
                        <graphic>
                            <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                                <Image url="@../images/collection-icon.png"/>
                            </ImageView>
                        </graphic>
                        <contentDisplay>TOP</contentDisplay>
                    </ToggleButton>
                    <ToggleButton fx:id="railEnvironmentsBtn" text="Environments" styleClass="rail-btn"
                                  toggleGroup="$sidebarRailGroup"
                                  onAction="#handleShowEnvironments" maxWidth="10000">
                        <graphic>
                            <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                                <Image url="@../images/folder-icon.png"/>
                            </ImageView>
                        </graphic>
                        <contentDisplay>TOP</contentDisplay>
                    </ToggleButton>
                    <ToggleButton fx:id="railHistoryBtn" text="History" styleClass="rail-btn"
                                  toggleGroup="$sidebarRailGroup"
                                  onAction="#handleShowHistory" maxWidth="10000">
                        <graphic>
                            <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                                <Image url="@../images/request-icon.png"/>
                            </ImageView>
                        </graphic>
                        <contentDisplay>TOP</contentDisplay>
                    </ToggleButton>
                    <ToggleButton fx:id="railTeamsBtn" text="Teams" styleClass="rail-btn"
                                  toggleGroup="$sidebarRailGroup"
                                  onAction="#handleShowTeams" maxWidth="10000">
                        <graphic>
                            <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                                <Image url="@../images/user-icon.png"/>
                            </ImageView>
                        </graphic>
                        <contentDisplay>TOP</contentDisplay>
                    </ToggleButton>
                    <ToggleButton fx:id="railMockServersBtn" text="Mock Servers" styleClass="rail-btn"
                                  toggleGroup="$sidebarRailGroup"
                                  onAction="#handleShowMockServers" maxWidth="10000">
                        <graphic>
                            <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                                <Image url="@../images/sample-icon.png"/>
                            </ImageView>
                        </graphic>
                        <contentDisplay>TOP</contentDisplay>
                    </ToggleButton>
                    <ToggleButton fx:id="railMonitorsBtn" text="Monitors" styleClass="rail-btn"
                                  toggleGroup="$sidebarRailGroup"
                                  onAction="#handleShowMonitors" maxWidth="10000">
                        <graphic>
                            <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                                <Image url="@../images/send-icon.png"/>
                            </ImageView>
                        </graphic>
                        <contentDisplay>TOP</contentDisplay>
                    </ToggleButton>
                </VBox>
                    <StackPane fx:id="sidebarContentPane" prefWidth="264" minWidth="140" maxWidth="560" styleClass="sidebar">
                    <!-- Collections pane (default) -->
                    <VBox fx:id="collectionsPane" spacing="6">
                        <padding>
                            <Insets top="8" right="8" bottom="8" left="8"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT" spacing="4" styleClass="sidebar-header">
                            <Label text="Collections" styleClass="section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button styleClass="icon-button" onAction="#handleAddRequest" fx:id="addRequestBtn">
                                <tooltip>
                                    <Tooltip text="New request"/>
                                </tooltip>
                                <graphic>
                                    <ImageView fitHeight="14" fitWidth="14" preserveRatio="true">
                                        <Image url="@../images/add-icon.png"/>
                                    </ImageView>
                                </graphic>
                            </Button>
                            <MenuButton styleClass="icon-button" fx:id="collectionsMenuBtn">
                                <graphic>
                                    <ImageView fitHeight="14" fitWidth="14" preserveRatio="true">
                                        <Image url="@../images/more-icon.png"/>
                                    </ImageView>
                                </graphic>
                                <items>
                                    <MenuItem text="New Collection" onAction="#handleNewCollection"/>
                                    <MenuItem text="Refresh" onAction="#handleRefreshCollections"/>
                                    <SeparatorMenuItem/>
                                    <MenuItem text="Import Collection…" onAction="#handleImportCollections"/>
                                    <MenuItem text="Export Collection…" onAction="#handleExportCollections"/>
                                </items>
                            </MenuButton>
                        </HBox>
                        <TextField fx:id="collectionsSearchField" styleClass="sidebar-search"
                                   promptText="Search collections"/>
                        <TreeView fx:id="collectionsTree" styleClass="collectionResponses-tree"
                                  showRoot="false" VBox.vgrow="ALWAYS"/>
                    </VBox>

                    <!-- Environments pane -->
                    <VBox fx:id="environmentsPane" spacing="6" visible="false">
                        <padding>
                            <Insets top="8" right="8" bottom="8" left="8"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT" styleClass="sidebar-header">
                            <Label text="Environments" styleClass="section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button styleClass="icon-button" onAction="#handleImportEnvironment">
                                <tooltip>
                                    <Tooltip text="Import environment from JSON"/>
                                </tooltip>
                                <graphic>
                                    <ImageView fitHeight="14" fitWidth="14" preserveRatio="true">
                                        <Image url="@../images/folder-icon.png"/>
                                    </ImageView>
                                </graphic>
                            </Button>
                            <Button styleClass="icon-button" onAction="#handleNewEnvironment">
                                <tooltip>
                                    <Tooltip text="New environment"/>
                                </tooltip>
                                <graphic>
                                    <ImageView fitHeight="14" fitWidth="14" preserveRatio="true">
                                        <Image url="@../images/add-icon.png"/>
                                    </ImageView>
                                </graphic>
                            </Button>
                        </HBox>
                        <Label styleClass="sidebar-hint" wrapText="true"
                               text="Double-click an environment to edit its variables. Pick the active one at the top right."/>
                        <ListView fx:id="environmentsList" styleClass="history-list" VBox.vgrow="ALWAYS"/>
                    </VBox>

                    <!-- History pane -->
                    <VBox fx:id="historyPane" spacing="6" visible="false">
                        <padding>
                            <Insets top="8" right="8" bottom="8" left="8"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT" styleClass="sidebar-header">
                            <Label text="History" styleClass="section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button styleClass="icon-button" onAction="#handleClearHistory">
                                <tooltip>
                                    <Tooltip text="Clear history"/>
                                </tooltip>
                                <graphic>
                                    <ImageView fitHeight="14" fitWidth="14" preserveRatio="true">
                                        <Image url="@../images/clear-icon.png"/>
                                    </ImageView>
                                </graphic>
                            </Button>
                        </HBox>
                        <ListView fx:id="historyList" styleClass="history-list" VBox.vgrow="ALWAYS"/>
                    </VBox>

                    <!-- Teams pane -->
                    <VBox fx:id="teamsPane" spacing="6" visible="false">
                        <padding>
                            <Insets top="8" right="8" bottom="8" left="8"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT" styleClass="sidebar-header">
                            <Label text="Teams" styleClass="section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button styleClass="icon-button" onAction="#handleJoinTeam">
                                <tooltip>
                                    <Tooltip text="Join a team with an invite code"/>
                                </tooltip>
                                <graphic>
                                    <ImageView fitHeight="14" fitWidth="14" preserveRatio="true">
                                        <Image url="@../images/folder-icon.png"/>
                                    </ImageView>
                                </graphic>
                            </Button>
                            <Button styleClass="icon-button" onAction="#handleCreateTeam">
                                <tooltip>
                                    <Tooltip text="Create a team"/>
                                </tooltip>
                                <graphic>
                                    <ImageView fitHeight="14" fitWidth="14" preserveRatio="true">
                                        <Image url="@../images/add-icon.png"/>
                                    </ImageView>
                                </graphic>
                            </Button>
                        </HBox>
                        <Label styleClass="sidebar-hint" wrapText="true"
                               text="Double-click a team to manage members and invitations."/>
                        <ListView fx:id="teamsList" styleClass="history-list" VBox.vgrow="ALWAYS"/>
                    </VBox>

                    <!-- Mock Servers pane -->
                    <VBox fx:id="mockServersPane" spacing="6" visible="false">
                        <padding>
                            <Insets top="8" right="8" bottom="8" left="8"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT" styleClass="sidebar-header">
                            <Label text="Mock Servers" styleClass="section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button styleClass="icon-button" onAction="#handleCreateMockServer">
                                <tooltip>
                                    <Tooltip text="Create a mock server"/>
                                </tooltip>
                                <graphic>
                                    <ImageView fitHeight="14" fitWidth="14" preserveRatio="true">
                                        <Image url="@../images/add-icon.png"/>
                                    </ImageView>
                                </graphic>
                            </Button>
                        </HBox>
                        <Label styleClass="sidebar-hint" wrapText="true"
                               text="Double-click a mock server to manage its routes."/>
                        <ListView fx:id="mockServersList" styleClass="history-list" VBox.vgrow="ALWAYS"/>
                    </VBox>

                    <!-- Monitors pane -->
                    <VBox fx:id="monitorsPane" spacing="6" visible="false">
                        <padding>
                            <Insets top="8" right="8" bottom="8" left="8"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT" styleClass="sidebar-header">
                            <Label text="Monitors" styleClass="section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button styleClass="icon-button" onAction="#handleCreateMonitor">
                                <tooltip>
                                    <Tooltip text="Create a monitor"/>
                                </tooltip>
                                <graphic>
                                    <ImageView fitHeight="14" fitWidth="14" preserveRatio="true">
                                        <Image url="@../images/add-icon.png"/>
                                    </ImageView>
                                </graphic>
                            </Button>
                        </HBox>
                        <Label styleClass="sidebar-hint" wrapText="true"
                               text="Double-click a monitor to see run history or run it now."/>
                        <ListView fx:id="monitorsList" styleClass="history-list" VBox.vgrow="ALWAYS"/>
                    </VBox>
                </StackPane>
                    <SplitPane orientation="VERTICAL" dividerPositions="0.55" styleClass="main-split">
                <!-- Request builder -->
                <VBox styleClass="requestResponse-panel">
                    <!-- Postman-style open-request tabs -->
                    <TabPane fx:id="requestTabPane" styleClass="request-tab-bar"
                             tabClosingPolicy="ALL_TABS"
                             minHeight="36" prefHeight="36" maxHeight="36"/>
                    <HBox styleClass="url-bar" spacing="8" alignment="CENTER_LEFT">
                        <ComboBox fx:id="methodCombo" styleClass="method-combo" prefWidth="110"/>
                        <StackPane HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                            <Label fx:id="urlPromptLabel" styleClass="url-prompt-label"
                                   text="Enter URL or paste text — use {{variables}} from the selected environment"
                                   mouseTransparent="true"/>
                            <CodeArea fx:id="urlField" styleClass="url-field"/>
                        </StackPane>
                        <Button text="Send" fx:id="sendBtn" styleClass="send-button" onAction="#handleSendRequest"/>
                        <Button text="Connect" fx:id="wsConnectBtn" styleClass="send-button" visible="false" managed="false"
                                onAction="#handleWsConnectToggle"/>
                        <Button text="Connect" fx:id="socketIoConnectBtn" styleClass="send-button" visible="false" managed="false"
                                onAction="#handleSocketIoConnectToggle"/>
                        <Button styleClass="icon-button" onAction="#handleSaveRequest">
                            <tooltip>
                                <Tooltip text="Save request"/>
                            </tooltip>
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                    <Image url="@../images/save-icon.png"/>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button styleClass="icon-button" onAction="#handleSamplePostRequest">
                            <tooltip>
                                <Tooltip text="Load sample POST request"/>
                            </tooltip>
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                    <Image url="@../images/sample-icon.png"/>
                                </ImageView>
                            </graphic>
                        </Button>
                    </HBox>

                    <!-- Request tabs: Postman order -->
                    <TabPane fx:id="requestBuilderTabPane" styleClass="requestResponse-tabs"
                             tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                        <tabs>
                            <!-- Only meaningful when method = WS, but always present so it's
                                 never hidden behind a mode switch — matches Postman's own
                                 layout, where Message is the primary WS tab. -->
                            <Tab text="Message" fx:id="wsMessageTab">
                                <VBox spacing="8">
                                    <padding>
                                        <Insets top="10" right="10" bottom="10" left="10"/>
                                    </padding>
                                    <Label text="Connect first, then compose a message below and send it over the open socket."
                                           wrapText="true" styleClass="ws-status-label"/>
                                    <TextArea fx:id="wsMessageComposeArea" promptText="Type a message to send..."
                                              wrapText="true" VBox.vgrow="ALWAYS"/>
                                    <HBox alignment="CENTER_RIGHT" spacing="8">
                                        <Button text="Send" onAction="#handleWsSendMessage" styleClass="send-button"/>
                                    </HBox>
                                </VBox>
                            </Tab>
                            <Tab text="Socket.IO" fx:id="socketIoTab">
                                <VBox spacing="8">
                                    <padding>
                                        <Insets top="10" right="10" bottom="10" left="10"/>
                                    </padding>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label text="Namespace"/>
                                        <TextField fx:id="socketIoNamespaceField" promptText="/ (default)" prefWidth="160"/>
                                        <Label fx:id="socketIoStatusLabel" text="Not connected" styleClass="ws-status-label"/>
                                    </HBox>
                                    <ListView fx:id="socketIoEventLog" styleClass="ws-message-log" VBox.vgrow="ALWAYS"/>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <TextField fx:id="socketIoEventNameField" promptText="Event name, e.g. chat message" prefWidth="200"/>
                                        <TextField fx:id="socketIoEventDataField" promptText="Data (JSON or plain text)"
                                                   HBox.hgrow="ALWAYS" onAction="#handleSocketIoEmit"/>
                                        <Button text="Emit" onAction="#handleSocketIoEmit" styleClass="add-row-button"/>
                                    </HBox>
                                </VBox>
                            </Tab>
                            <Tab text="Params">
                                <VBox>
                                    <TableView fx:id="paramsTable" styleClass="key-value-table" VBox.vgrow="ALWAYS"/>
                                    <HBox alignment="CENTER_RIGHT" styleClass="table-button-bar" spacing="8">
                                        <Button text="Add Row" onAction="#handleAddParamRow"
                                                styleClass="add-row-button"/>
                                        <Button text="Delete Row" onAction="#handleDeleteParamRow"
                                                styleClass="delete-row-button"/>
                                    </HBox>
                                </VBox>
                            </Tab>

                            <Tab text="Authorization">
                                <HBox spacing="24" styleClass="auth-panel">
                                    <VBox spacing="10" minWidth="200" maxWidth="200">
                                        <Label text="Auth Type" styleClass="scripts-section-label"/>
                                        <ComboBox fx:id="authTypeCombo" promptText="Select Auth Type" prefWidth="190"/>
                                        <Label fx:id="authHintLabel" styleClass="sidebar-hint" wrapText="true"
                                               text="The authorization header will be generated automatically when you send the request."/>
                                    </VBox>
                                    <VBox spacing="14" HBox.hgrow="ALWAYS">
                                        <!-- Bearer Token -->
                                        <VBox fx:id="bearerAuthBox" spacing="6" managed="false" visible="false">
                                            <Label text="Token" styleClass="scripts-section-label"/>
                                            <StackPane>
                                                <Label fx:id="tokenPromptLabel" styleClass="url-prompt-label"
                                                       text="{{Token}} or paste a token" mouseTransparent="true"/>
                                                <CodeArea fx:id="tokenField" styleClass="url-field"/>
                                            </StackPane>
                                        </VBox>
                                        <!-- Basic Auth -->
                                        <VBox fx:id="basicAuthBox" spacing="12" managed="false" visible="false">
                                            <VBox spacing="6">
                                                <Label text="Username" styleClass="scripts-section-label"/>
                                                <StackPane>
                                                    <Label fx:id="usernamePromptLabel" styleClass="url-prompt-label"
                                                           text="Username or {{variable}}" mouseTransparent="true"/>
                                                    <CodeArea fx:id="usernameField" styleClass="url-field"/>
                                                </StackPane>
                                            </VBox>
                                            <VBox spacing="6">
                                                <Label text="Password" styleClass="scripts-section-label"/>
                                                <PasswordField fx:id="passwordField" promptText="Password"/>
                                            </VBox>
                                        </VBox>
                                        <!-- OAuth 2.0 -->
                                        <VBox fx:id="oauth2Box" spacing="12" managed="false" visible="false">
                                            <HBox spacing="10" alignment="CENTER_LEFT">
                                                <Label text="Add auth data to" prefWidth="140"/>
                                                <ComboBox fx:id="oauth2AddToCombo" prefWidth="200"/>
                                            </HBox>
                                            <Label text="Current Token" styleClass="scripts-section-label"/>
                                            <HBox spacing="10" alignment="CENTER_LEFT">
                                                <Label text="Token" prefWidth="140"/>
                                                <TextField fx:id="oauth2CurrentTokenField" promptText="(none yet)"
                                                           HBox.hgrow="ALWAYS"/>
                                            </HBox>
                                            <HBox spacing="10" alignment="CENTER_LEFT">
                                                <Label text="Header Prefix" prefWidth="140"/>
                                                <TextField fx:id="oauth2HeaderPrefixField" text="Bearer" prefWidth="200"/>
                                            </HBox>
                                            <Separator/>
                                            <Label text="Configure New Token" styleClass="scripts-section-label"/>
                                            <HBox spacing="10" alignment="CENTER_LEFT">
                                                <Label text="Grant Type" prefWidth="140"/>
                                                <ComboBox fx:id="oauth2GrantTypeCombo" prefWidth="260"/>
                                            </HBox>
                                            <HBox fx:id="oauth2AuthUrlRow" spacing="10" alignment="CENTER_LEFT">
                                                <Label text="Auth URL" prefWidth="140"/>
                                                <TextField fx:id="oauth2AuthUrlField" promptText="https://.../authorize"
                                                           HBox.hgrow="ALWAYS"/>
                                            </HBox>
                                            <HBox spacing="10" alignment="CENTER_LEFT">
                                                <Label text="Access Token URL" prefWidth="140"/>
                                                <TextField fx:id="oauth2TokenUrlField" promptText="https://.../oauth/token"
                                                           HBox.hgrow="ALWAYS"/>
                                            </HBox>
                                            <HBox spacing="10" alignment="CENTER_LEFT">
                                                <Label text="Client ID" prefWidth="140"/>
                                                <TextField fx:id="oauth2ClientIdField" HBox.hgrow="ALWAYS"/>
                                            </HBox>
                                            <HBox spacing="10" alignment="CENTER_LEFT">
                                                <Label text="Client Secret" prefWidth="140"/>
                                                <PasswordField fx:id="oauth2ClientSecretField" HBox.hgrow="ALWAYS"/>
                                            </HBox>
                                            <HBox spacing="10" alignment="CENTER_LEFT">
                                                <Label text="Scope" prefWidth="140"/>
                                                <TextField fx:id="oauth2ScopeField" HBox.hgrow="ALWAYS"/>
                                            </HBox>
                                            <HBox fx:id="oauth2UsernameRow" spacing="10" alignment="CENTER_LEFT">
                                                <Label text="Username" prefWidth="140"/>
                                                <TextField fx:id="oauth2UsernameField" HBox.hgrow="ALWAYS"/>
                                            </HBox>
                                            <HBox fx:id="oauth2PasswordRow" spacing="10" alignment="CENTER_LEFT">
                                                <Label text="Password" prefWidth="140"/>
                                                <PasswordField fx:id="oauth2PasswordField" HBox.hgrow="ALWAYS"/>
                                            </HBox>
                                            <HBox spacing="10" alignment="CENTER_LEFT">
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Button text="Get New Access Token" styleClass="run-tests-btn"
                                                        onAction="#handleGetOAuth2Token"/>
                                            </HBox>
                                            <Label fx:id="oauth2StatusLabel" styleClass="sidebar-hint" wrapText="true"/>
                                        </VBox>
                                    </VBox>
                                </HBox>
                            </Tab>

                            <Tab text="Headers">
                                <VBox>
                                    <TableView fx:id="headersTable" styleClass="key-value-table" VBox.vgrow="ALWAYS"/>
                                    <HBox alignment="CENTER_RIGHT" styleClass="table-button-bar" spacing="8">
                                        <Button text="Add Row" onAction="#handleAddHeaderRow"
                                                styleClass="add-row-button"/>
                                        <Button text="Delete Row" onAction="#handleDeleteHeaderRow"
                                                styleClass="delete-row-button"/>
                                    </HBox>
                                </VBox>
                            </Tab>

                            <Tab text="Body">
                                <VBox>
                                    <HBox styleClass="body-type-selector">
                                        <ToggleButton fx:id="noneBodyTypeButton" text="None"
                                                      styleClass="body-type-btn"/>
                                        <ToggleButton fx:id="rawBodyTypeButton" text="Raw" styleClass="body-type-btn"/>
                                        <ToggleButton fx:id="formDataBodyTypeButton" text="Form Data"
                                                      styleClass="body-type-btn"/>
                                        <ToggleButton fx:id="urlEncodedBodyTypeButton" text="x-www-form-urlencoded"
                                                      styleClass="body-type-btn"/>
                                        <ToggleButton fx:id="graphqlBodyTypeButton" text="GraphQL"
                                                      styleClass="body-type-btn"/>
                                    </HBox>
                                    <StackPane VBox.vgrow="ALWAYS">
                                        <Label fx:id="bodyPromptLabel" styleClass="body-prompt-label"
                                               text="Request body content" mouseTransparent="true"/>
                                        <CodeArea fx:id="bodyTextArea" styleClass="body-textarea"/>
                                        <TableView fx:id="formDataTable" styleClass="key-value-table" visible="false"/>
                                        <TableView fx:id="urlEncodedTable" styleClass="key-value-table" visible="false"/>
                                        <SplitPane fx:id="graphqlPane" orientation="VERTICAL" dividerPositions="0.65"
                                                   visible="false" styleClass="graphql-split">
                                            <VBox spacing="4">
                                                <Label text="Query" styleClass="graphql-section-label"/>
                                                <CodeArea fx:id="graphqlQueryArea" styleClass="body-textarea"
                                                          VBox.vgrow="ALWAYS"/>
                                            </VBox>
                                            <VBox spacing="4">
                                                <Label text="Query Variables (JSON)" styleClass="graphql-section-label"/>
                                                <CodeArea fx:id="graphqlVariablesArea" styleClass="body-textarea"
                                                          VBox.vgrow="ALWAYS"/>
                                            </VBox>
                                        </SplitPane>
                                    </StackPane>
                                    <HBox alignment="CENTER_RIGHT" styleClass="table-button-bar" spacing="8">
                                        <Button text="Add Row" onAction="#handleAddFormDataRow"
                                                styleClass="add-row-button"/>
                                        <Button text="Delete Row" onAction="#handleDeleteFormDataRow"
                                                styleClass="delete-row-button"/>
                                    </HBox>
                                </VBox>
                            </Tab>

                            <Tab text="Scripts">
                                <VBox spacing="10" styleClass="scripts-panel">
                                    <Label text="Pre-request Scripts" styleClass="scripts-section-label"/>
                                    <TextArea fx:id="preRequestScriptsArea"
                                              promptText="Runs before send. Supported: pm.environment.set(&quot;KEY&quot;, &quot;value&quot;), pm.environment.get(&quot;KEY&quot;), pm.environment.unset(&quot;KEY&quot;)"
                                              styleClass="scripts-textarea" VBox.vgrow="ALWAYS"/>
                                    <Label text="Tests (Post-request Scripts)" styleClass="scripts-section-label"/>
                                    <TextArea fx:id="postRequestScriptsArea"
                                              promptText="Runs after the response. Supported: const d = pm.response.json().data;  pm.environment.set(&quot;TOKEN&quot;, d.token);  pm.response.code"
                                              styleClass="scripts-textarea" VBox.vgrow="ALWAYS"/>
                                    <HBox spacing="10" alignment="CENTER_RIGHT">
                                        <Button text="Run Tests" onAction="#handleRunTests" styleClass="run-tests-btn"/>
                                    </HBox>
                                </VBox>
                            </Tab>
                        </tabs>
                    </TabPane>
                </VBox>

                <!-- Response viewer -->
                <VBox styleClass="response-panel">
                    <HBox styleClass="response-status-bar" spacing="15" alignment="CENTER_LEFT">
                        <Label text="Response" styleClass="response-title"/>
                        <Label fx:id="statusLabel" text="Status: " styleClass="status-label"/>
                        <Label fx:id="timeLabel" text="Time: " styleClass="time-label"/>
                        <Label fx:id="sizeLabel" text="Size: " styleClass="size-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button styleClass="icon-button" onAction="#handleCopyResponse">
                            <tooltip>
                                <Tooltip text="Copy response"/>
                            </tooltip>
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                    <Image url="@../images/copy-icon.png"/>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button styleClass="icon-button" onAction="#handleSaveResponse">
                            <tooltip>
                                <Tooltip text="Save response"/>
                            </tooltip>
                            <graphic>
                                <ImageView fitWidth="16" fitHeight="16" preserveRatio="true">
                                    <Image url="@../images/save-icon.png"/>
                                </ImageView>
                            </graphic>
                        </Button>
                    </HBox>

                    <TabPane styleClass="response-tabs" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                        <tabs>
                            <Tab text="Body">
                                <SplitPane orientation="HORIZONTAL" dividerPositions="0.7">
                                    <StackPane>
                                        <Label fx:id="responsePromptLabel" styleClass="response-prompt-label"
                                               text="Click Send to get a response" mouseTransparent="true"/>
                                        <CodeArea fx:id="responseBodyArea" styleClass="response-body" editable="false"/>
                                        <VBox fx:id="responseSearchBarContainer" alignment="TOP_RIGHT"
                                              pickOnBounds="false" StackPane.alignment="TOP_RIGHT">
                                            <padding>
                                                <Insets top="8" right="8"/>
                                            </padding>
                                        </VBox>
                                    </StackPane>
                                    <WebView fx:id="responsePreview"/>
                                </SplitPane>
                            </Tab>
                            <Tab text="Messages" fx:id="wsMessagesTab">
                                <VBox spacing="6">
                                    <padding>
                                        <Insets top="6" right="6" bottom="6" left="6"/>
                                    </padding>
                                    <Label fx:id="wsStatusLabel" text="Not connected — select the WS method and click Connect"
                                           styleClass="ws-status-label"/>
                                    <ListView fx:id="wsMessageLog" styleClass="ws-message-log" VBox.vgrow="ALWAYS"/>
                                </VBox>
                            </Tab>
                            <Tab text="Cookies">
                                <TableView fx:id="cookiesTable" styleClass="key-value-table"/>
                            </Tab>
                            <Tab text="Headers">
                                <TableView fx:id="responseHeadersTable" styleClass="key-value-table"/>
                            </Tab>
                            <Tab text="Tests">
                                <VBox spacing="10">
                                    <Label styleClass="sidebar-hint" wrapText="true"
                                           text="Results from the request's Scripts tab appear here automatically after each Send."/>
                                    <ListView fx:id="testResultsList" styleClass="test-results" VBox.vgrow="ALWAYS"/>
                                </VBox>
                            </Tab>
                        </tabs>
                    </TabPane>
                </VBox>
            </SplitPane>
                </SplitPane>
        </center>

        <!-- ============ BOTTOM: status bar ============ -->
        <bottom>
            <HBox styleClass="status-bar" spacing="10" alignment="CENTER_LEFT">
                <Label text="Ready" fx:id="statusMessage" styleClass="status-message"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="v1.0.0" styleClass="version-label"/>
            </HBox>
        </bottom>
    </BorderPane>
</StackPane>
