<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.web.WebView?>
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.roze.thundercall.ui.controllers.MainController"
           stylesheets="@../css/main.css">
    <BorderPane>
        <!-- Top Navigation Bar -->
        <top>
            <HBox styleClass="header" spacing="10" alignment="CENTER_LEFT" prefHeight="60">
                <padding>
                    <Insets left="20" right="20" top="10" bottom="10"/>
                </padding>
                <!-- Logo and App Name -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <ImageView fitHeight="32" fitWidth="32" preserveRatio="true">
                        <Image url="@../images/logo.png"/>
                    </ImageView>
                    <Text text="Thundercall" styleClass="app-title"/>
                </HBox>

                <!-- Spacer -->
                <Region HBox.hgrow="ALWAYS"/>
                <!-- Connection status -->
                <HBox alignment="CENTER" spacing="5" styleClass="connection-status">
                    <Circle radius="5" fill="green" styleClass="status-indicator"/>
                    <Label text="Connected" styleClass="status-text"/>
                </HBox>
                <!-- User Menu -->
                <MenuButton text="User" styleClass="user-menu">
                    <graphic>
                        <ImageView fitHeight="24" fitWidth="24" preserveRatio="true">
                            <Image url="@../images/user-icon.png"/>
                        </ImageView>
                    </graphic>
                    <items>
                        <MenuItem text="Profile" onAction="#handleProfile"/>
                        <MenuItem text="Settings" onAction="#handleSettings"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Logout" onAction="#handleLogout"/>
                    </items>
                </MenuButton>
            </HBox>
        </top>

        <!-- Left sidebar - Collections & history -->
        <left>
            <VBox prefWidth="250" styleClass="sidebar">
                <!-- Collections section -->
                <VBox styleClass="sidebar-section">
                    <HBox alignment="CENTER_LEFT" styleClass="sidebar-header">
                        <Label text="Collections" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <!-- Three-dot menu button -->
                        <MenuButton styleClass="icon-button" fx:id="collectionsMenuBtn">
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                    <Image url="@../images/more-icon.png"/>
                                </ImageView>
                            </graphic>
                            <items>
                                <MenuItem text="New Collection" onAction="#handleNewCollection"/>
                                <MenuItem text="Refresh" onAction="#handleRefreshCollections"/>
                                <SeparatorMenuItem/>
                                <MenuItem text="Import" onAction="#handleImportCollections"/>
                                <MenuItem text="Export" onAction="#handleExportCollections"/>
                            </items>
                        </MenuButton>
                        <!-- Plus button to add requestResponse -->
                        <Button styleClass="icon-button" onAction="#handleAddRequest" fx:id="addRequestBtn">
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                    <Image url="@../images/add-icon.png"/>
                                </ImageView>
                            </graphic>
                        </Button>
                    </HBox>
                    <TreeView fx:id="collectionsTree" styleClass="collectionResponses-tree" showRoot="false"
                              prefHeight="300"/>
                </VBox>

                <!-- Environment section -->
                <VBox styleClass="sidebar-section">
                    <HBox alignment="CENTER_LEFT" styleClass="sidebar-header">
                        <Label text="Environments" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button styleClass="icon-button" onAction="#handleNewEnvironment">
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                    <Image url="@../images/add-icon.png"/>
                                </ImageView>
                            </graphic>
                        </Button>
                    </HBox>
                    <ComboBox fx:id="environmentCombo" styleClass="environment-combo" promptText="Select Environment"/>
                </VBox>

                <VBox styleClass="sidebar-section" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" styleClass="sidebar-header">
                        <Label text="History" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button styleClass="icon-button" onAction="#handleClearHistory">
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                    <Image url="@../images/clear-icon.png"/>
                                </ImageView>
                            </graphic>
                        </Button>
                    </HBox>
                    <ListView fx:id="historyList" styleClass="history-list"/>
                </VBox>
            </VBox>
        </left>

        <!-- Center Content - Request Builder and Response Viewer -->
        <center>
            <SplitPane orientation="VERTICAL" dividerPositions="0.6" styleClass="main-split">
                <!-- Request Builder -->
                <VBox styleClass="requestResponse-panel">
                    <!-- Request URL Bar -->
                    <HBox styleClass="url-bar" spacing="10" alignment="CENTER_LEFT">
                        <ComboBox fx:id="methodCombo" styleClass="method-combo" prefWidth="100"/>
                        <TextField fx:id="urlField" styleClass="url-field" promptText="Enter Request URL"
                                   HBox.hgrow="ALWAYS"/>
                        <Button text="Send" styleClass="send-button" onAction="#handleSendRequest">
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                    <Image url="@../images/send-icon.png"/>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button styleClass="icon-button" onAction="#handleSaveRequest">
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                    <Image url="@../images/save-icon.png"/>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button styleClass="icon-button" onAction="#handleSamplePostRequest">
                            <tooltip>
                                <Tooltip text="Load sample POST requestResponse"/>
                            </tooltip>
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                    <Image url="@../images/sample-icon.png"/>
                                </ImageView>
                            </graphic>
                        </Button>
                    </HBox>

                    <!-- Request Tabs -->
                    <TabPane styleClass="requestResponse-tabs" tabClosingPolicy="UNAVAILABLE">
                        <tabs>
                            <!-- Params Tab -->
                            <Tab text="Params">
                                <VBox>
                                    <TableView fx:id="paramsTable" styleClass="key-value-table">
                                        <columns>
                                            <TableColumn text="Key" prefWidth="150">
                                                <cellValueFactory>
                                                    <PropertyValueFactory property="key"/>
                                                </cellValueFactory>
                                                <cellFactory>
                                                    <TextFieldTableCell fx:factory="forTableColumn"/>
                                                </cellFactory>
                                            </TableColumn>
                                            <TableColumn text="Value" prefWidth="200">
                                                <cellValueFactory>
                                                    <PropertyValueFactory property="value"/>
                                                </cellValueFactory>
                                                <cellFactory>
                                                    <TextFieldTableCell fx:factory="forTableColumn"/>
                                                </cellFactory>
                                            </TableColumn>
                                            <TableColumn text="Description" prefWidth="150">
                                                <cellValueFactory>
                                                    <PropertyValueFactory property="description"/>
                                                </cellValueFactory>
                                                <cellFactory>
                                                    <TextFieldTableCell fx:factory="forTableColumn"/>
                                                </cellFactory>
                                            </TableColumn>
                                        </columns>
                                    </TableView>
                                    <HBox alignment="CENTER_RIGHT" styleClass="table-button-bar">
                                        <Button text="Add Row" onAction="#handleAddParamRow"
                                                styleClass="add-row-button"/>
                                        <Button text="Delete Row" onAction="#handleDeleteParamRow"
                                                styleClass="delete-row-button"/>
                                    </HBox>
                                </VBox>
                            </Tab>

                            <!-- Headers Tab -->
                            <Tab text="Headers">
                                <VBox>
                                    <TableView fx:id="headersTable" styleClass="key-value-table">
                                        <columns>
                                            <TableColumn text="Key" prefWidth="150">
                                                <cellValueFactory>
                                                    <PropertyValueFactory property="key"/>
                                                </cellValueFactory>
                                                <cellFactory>
                                                    <TextFieldTableCell fx:factory="forTableColumn"/>
                                                </cellFactory>
                                            </TableColumn>
                                            <TableColumn text="Value" prefWidth="200">
                                                <cellValueFactory>
                                                    <PropertyValueFactory property="value"/>
                                                </cellValueFactory>
                                                <cellFactory>
                                                    <TextFieldTableCell fx:factory="forTableColumn"/>
                                                </cellFactory>
                                            </TableColumn>
                                            <TableColumn text="Description" prefWidth="150">
                                                <cellValueFactory>
                                                    <PropertyValueFactory property="description"/>
                                                </cellValueFactory>
                                                <cellFactory>
                                                    <TextFieldTableCell fx:factory="forTableColumn"/>
                                                </cellFactory>
                                            </TableColumn>
                                        </columns>
                                    </TableView>
                                    <HBox alignment="CENTER_RIGHT" styleClass="table-button-bar">
                                        <Button text="Add Row" onAction="#handleAddHeaderRow"
                                                styleClass="add-row-button"/>
                                        <Button text="Delete Row" onAction="#handleDeleteHeaderRow"
                                                styleClass="delete-row-button"/>
                                    </HBox>
                                </VBox>
                            </Tab>

                            <!-- Body Tab -->
                            <Tab text="Body">
                                <VBox>
                                    <HBox styleClass="body-type-selector">
                                        <ToggleButton fx:id="noneBodyTypeButton" text="None"
                                                      styleClass="body-type-btn"/>
                                        <ToggleButton fx:id="rawBodyTypeButton" text="Raw" styleClass="body-type-btn"/>
                                        <ToggleButton fx:id="formDataBodyTypeButton" text="Form Data"
                                                      styleClass="body-type-btn"/>
                                        <ToggleButton fx:id="urlEncodedBodyTypeButton" text="x-www-form-urlencoded"
                                                      styleClass="body-type-btn"/>
                                    </HBox>
                                    <StackPane>
                                        <TextArea fx:id="bodyTextArea" styleClass="body-textarea"
                                                  promptText="Request body content"/>
                                        <TableView fx:id="formDataTable" styleClass="key-value-table" visible="false">
                                            <columns>
                                                <TableColumn text="Key" prefWidth="150">
                                                    <cellValueFactory>
                                                        <PropertyValueFactory property="key"/>
                                                    </cellValueFactory>
                                                    <cellFactory>
                                                        <TextFieldTableCell fx:factory="forTableColumn"/>
                                                    </cellFactory>
                                                </TableColumn>
                                                <TableColumn text="Value" prefWidth="200">
                                                    <cellValueFactory>
                                                        <PropertyValueFactory property="value"/>
                                                    </cellValueFactory>
                                                    <cellFactory>
                                                        <TextFieldTableCell fx:factory="forTableColumn"/>
                                                    </cellFactory>
                                                </TableColumn>
                                                <TableColumn text="Description" prefWidth="150">
                                                    <cellValueFactory>
                                                        <PropertyValueFactory property="description"/>
                                                    </cellValueFactory>
                                                    <cellFactory>
                                                        <TextFieldTableCell fx:factory="forTableColumn"/>
                                                    </cellFactory>
                                                </TableColumn>
                                            </columns>
                                        </TableView>
                                    </StackPane>
                                    <HBox alignment="CENTER_RIGHT" styleClass="table-button-bar">
                                        <Button text="Add Row" onAction="#handleAddFormDataRow"
                                                styleClass="add-row-button"/>
                                        <Button text="Delete Row" onAction="#handleDeleteFormDataRow"
                                                styleClass="delete-row-button"/>
                                    </HBox>
                                </VBox>
                            </Tab>

                            <!-- Auth Tab -->
                            <Tab text="Auth">
                                <VBox spacing="10" styleClass="auth-panel">
                                    <ComboBox fx:id="authTypeCombo" promptText="Select Auth Type"/>
                                    <TextField fx:id="tokenField" promptText="Enter token" visible="false"/>
                                    <HBox spacing="10" visible="false">
                                        <TextField fx:id="usernameField" promptText="Username" HBox.hgrow="ALWAYS"/>
                                        <PasswordField fx:id="passwordField" promptText="Password" HBox.hgrow="ALWAYS"/>
                                    </HBox>
                                </VBox>
                            </Tab>
                            <!-- Add this Tab to your Request Tabs section -->
                            <Tab text="Scripts">
                                <VBox spacing="10" styleClass="scripts-panel">
                                    <Label text="Pre-request Scripts" styleClass="scripts-section-label"/>
                                    <TextArea fx:id="preRequestScriptsArea"
                                              promptText="Write scripts to run before request"
                                              styleClass="scripts-textarea"/>

                                    <Label text="Tests (Post-request Scripts)" styleClass="scripts-section-label"/>
                                    <TextArea fx:id="postRequestScriptsArea"
                                              promptText="Write scripts to run after response"
                                              styleClass="scripts-textarea"/>

                                    <HBox spacing="10" alignment="CENTER_RIGHT">
                                        <!--                                        <Button text="Run Pre-request Scripts" onAction="#handleRunPreRequestScripts"-->
                                        <!--                                                styleClass="run-scripts-btn"/>-->
                                        <Button text="Run Pre-request Scripts"
                                                styleClass="run-scripts-btn"/>
                                        <Button text="Run Tests" onAction="#handleRunTests" styleClass="run-tests-btn"/>
                                    </HBox>
                                </VBox>
                            </Tab>
                        </tabs>
                    </TabPane>
                </VBox>

                <!-- Response Viewer -->
                <VBox styleClass="response-panel">
                    <!-- Response status bar -->
                    <HBox styleClass="response-status-bar" spacing="15" alignment="CENTER_LEFT">
                        <Label fx:id="statusLabel" text="Status: " styleClass="status-label"/>
                        <Label fx:id="timeLabel" text="Time: " styleClass="time-label"/>
                        <Label fx:id="sizeLabel" text="Size: " styleClass="size-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button styleClass="icon-button" onAction="#handleCopyResponse">
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                    <Image url="@../images/copy-icon.png"/>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button styleClass="icon-button" onAction="#handleSaveResponse">
                            <graphic>
                                <ImageView fitWidth="16" fitHeight="16" preserveRatio="true">
                                    <Image url="@../images/save-icon.png"/>
                                </ImageView>
                            </graphic>
                        </Button>
                    </HBox>

                    <!-- Response Tabs -->
                    <TabPane styleClass="response-tabs" tabClosingPolicy="UNAVAILABLE">
                        <tabs>
                            <Tab text="Body">
                                <SplitPane orientation="HORIZONTAL" dividerPositions="0.7">
                                    <TextArea fx:id="responseBodyArea" styleClass="response-body" editable="false"/>
                                    <WebView fx:id="responsePreview" styleClass="response-preview"/>
                                </SplitPane>
                            </Tab>
                            <Tab text="Headers">
                                <TableView fx:id="responseHeadersTable" styleClass="key-value-table">
                                    <columns>
                                        <TableColumn text="Key" prefWidth="150">
                                            <cellValueFactory>
                                                <PropertyValueFactory property="key"/>
                                            </cellValueFactory>
                                        </TableColumn>
                                        <TableColumn text="Value" prefWidth="300">
                                            <cellValueFactory>
                                                <PropertyValueFactory property="value"/>
                                            </cellValueFactory>
                                        </TableColumn>
                                    </columns>
                                </TableView>
                            </Tab>
                            <Tab text="Cookies">
                                <TableView fx:id="cookiesTable" styleClass="key-value-table">
                                    <columns>
                                        <TableColumn text="Name" prefWidth="150">
                                            <cellValueFactory>
                                                <PropertyValueFactory property="key"/>
                                            </cellValueFactory>
                                        </TableColumn>
                                        <TableColumn text="Value" prefWidth="200">
                                            <cellValueFactory>
                                                <PropertyValueFactory property="value"/>
                                            </cellValueFactory>
                                        </TableColumn>
                                        <TableColumn text="Domain" prefWidth="150">
                                            <cellValueFactory>
                                                <PropertyValueFactory property="description"/>
                                            </cellValueFactory>
                                        </TableColumn>
                                    </columns>
                                </TableView>
                            </Tab>
                            <Tab text="Tests">
                                <VBox spacing="10">
                                    <TextArea fx:id="testsArea" promptText="Write test scripts here"
                                              styleClass="tests-textarea"/>
                                    <Button text="Run Tests" onAction="#handleRunTests" styleClass="run-tests-btn"/>
                                    <ListView fx:id="testResultsList" styleClass="test-results"/>
                                </VBox>
                            </Tab>
                        </tabs>
                    </TabPane>
                </VBox>
            </SplitPane>
        </center>

        <bottom>
            <HBox styleClass="status-bar" spacing="10" alignment="CENTER_LEFT">
                <Label text="Ready" fx:id="statusMessage" styleClass="status-message"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="v1.0.0" styleClass="version-label"/>
            </HBox>
        </bottom>
    </BorderPane>
</StackPane>