<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.roze.thundercall.ui.controllers.VerifyEmailController"
      stylesheets="@../css/main.css"
      styleClass="auth-root">

    <!-- ================= Left: brand panel ================= -->
    <VBox styleClass="brand-panel" alignment="CENTER_LEFT" spacing="18"
          prefWidth="320" minWidth="280" HBox.hgrow="NEVER">
        <padding>
            <Insets top="48" right="36" bottom="48" left="36"/>
        </padding>

        <ImageView fitHeight="64" fitWidth="64" preserveRatio="true">
            <Image url="@../images/logo.png"/>
        </ImageView>

        <Label text="Thundercall" styleClass="brand-title" wrapText="true"/>
        <Label text="Build, test and organize your APIs — fast."
               styleClass="brand-tagline" wrapText="true"/>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox spacing="12">
            <Label text="📬  One quick step left" styleClass="brand-feature" wrapText="true"/>
            <Label text="🔒  Keeps your account secure" styleClass="brand-feature" wrapText="true"/>
            <Label text="⚡  Then you're straight into your workspace" styleClass="brand-feature" wrapText="true"/>
        </VBox>
    </VBox>

    <!-- ================= Right: form ================= -->
    <StackPane styleClass="auth-form-side" HBox.hgrow="ALWAYS">
        <VBox styleClass="auth-card" alignment="CENTER_LEFT" spacing="14"
              maxWidth="380" minWidth="320">
            <padding>
                <Insets top="36" right="36" bottom="36" left="36"/>
            </padding>

            <Label text="Verify your email" styleClass="auth-title" wrapText="true"/>
            <Label fx:id="subtitleLabel" text="Enter the 6-digit code we sent to your email"
                   styleClass="auth-subtitle" wrapText="true"/>

            <VBox spacing="6">
                <Label text="6-DIGIT CODE" styleClass="field-label"/>
                <TextField fx:id="codeField" promptText="000000" styleClass="verification-code-field"/>
            </VBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button fx:id="verifyButton" text="Verify &amp; continue" onAction="#handleVerify"
                        styleClass="primary-button" maxWidth="10000" HBox.hgrow="ALWAYS"/>
                <ProgressIndicator fx:id="loadingSpinner" visible="false"
                                   prefWidth="24" prefHeight="24"/>
            </HBox>

            <Label fx:id="statusLabel" styleClass="sidebar-hint" wrapText="true"/>

            <Separator styleClass="auth-separator"/>

            <HBox spacing="5" alignment="CENTER">
                <Hyperlink text="Didn't get it? Resend code" onAction="#handleResend" styleClass="auth-link"/>
            </HBox>
            <HBox spacing="5" alignment="CENTER">
                <Hyperlink text="Back to sign in" onAction="#handleBackToLogin" styleClass="auth-link"/>
            </HBox>
        </VBox>
    </StackPane>
</HBox>
