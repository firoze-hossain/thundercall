<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.roze.thundercall.ui.controllers.AuthController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"></Insets>
    </padding>
    <Text text="Api Client" style="-fx-font-size: 24px; -fx-font-weight: bold;"></Text>
    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100"></ColumnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="200"></ColumnConstraints>
        </columnConstraints>

        <Label text="Username:" GridPane.rowIndex="0" GridPane.columnIndex="0"></Label>
        <TextField fx:id="usernameField" promptText="Enter username" GridPane.rowIndex="0"
                   GridPane.columnIndex="1"></TextField>

        <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="0" fx:id="emailLabel" visible="false" managed="false"></Label>
        <TextField fx:id="emailField" promptText="Enter email" GridPane.rowIndex="1"
                   GridPane.columnIndex="1" visible="false" managed="false"></TextField>

        <Label text="Password:" GridPane.rowIndex="2" GridPane.columnIndex="0"></Label>
        <PasswordField fx:id="passwordField" promptText="Enter password" GridPane.rowIndex="2"
                       GridPane.columnIndex="1"></PasswordField>
    </GridPane>
    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="loginButton" text="Login" onAction="#handleAuthAction"></Button>
        <Button fx:id="registerButton" text="Register" onAction="#handleAuthAction" visible="false" managed="false"></Button>

        <ProgressIndicator fx:id="loadingSpinner" visible="false"></ProgressIndicator>

    </HBox>
    <Button fx:id="browserLoginButton" text="Login with browser" onAction="#handleBrowserLogin"></Button>

    <HBox spacing="5" alignment="CENTER">
        <Hyperlink fx:id="switchToRegisterLink" text="Create an account" onAction="#switchViewMode"></Hyperlink>
        <Hyperlink fx:id="switchToLoginLink" text="Already have an account" onAction="#switchViewMode"
                   visible="false" managed="false"></Hyperlink>
    </HBox>
</VBox>
